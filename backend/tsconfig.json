{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2024",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }, 
  "include": ["src/**/*",  "@types/*.d.ts", "prisma/seed.ts"],
  "exclude": ["node_modules"]
}
